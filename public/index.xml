      <description>&lt;section id=&#34;td-cover-block-0&#34; class=&#34;row td-cover-block td-cover-block--height-auto td-below-navbar js-td-cover td-overlay td-overlay--dark -bg-bg-info bg-gradient td-below-navbar&#34; &gt;&#xA;  &lt;div class=&#34;col-12&#34;&gt;&#xA;    &lt;div class=&#34;container td-overlay__inner&#34;&gt;&#xA;      &lt;div class=&#34;text-center&#34;&gt;&#xA;        &lt;h1 class=&#34;display-1 mt-0 mt-md-5 pb-4&#34;&gt;Volunteers Wanted&lt;/h1&gt;&#xA;        &lt;div class=&#34;pt-3 lead&#34;&gt;&#xA;&lt;!-- prettier-ignore --&gt;&#xD;&#xA;&lt;p class=&#34;display-6&#34;&gt;Start volunteering today.&lt;/p&gt;&#xA;&lt;p&gt;&lt;button type=&#34;button&#34; class=&#34;btn btn-primary&#34; data-bs-toggle=&#34;modal&#34; data-bs-target=&#34;#bootstrapModal&#34;&gt;Apply Now&lt;/button&gt;&lt;/p&gt;&#xA;&lt;div class=&#34;modal fade&#34; id=&#34;bootstrapModal&#34; role=&#34;dialog&#34; data-bs-backdrop=&#34;true&#34; data-bs-keyboard=&#34;false&#34; tabindex=&#34;-1&#34; aria-labelledby=&#34;boostrapModalLabel&#34; aria-hidden=&#34;true&#34;&gt;&#xD;&#xA;  &lt;div class=&#34;modal-dialog modal-dialog-centered modal-lg&#34; role=&#34;document&#34;&gt;&#xD;&#xA;      &lt;div class=&#34;modal-content&#34;&gt;&#xD;&#xA;          &lt;div class=&#34;modal-header&#34;&gt;&#xD;&#xA;              &lt;h5 class=&#34;modal-title fs-5&#34; id=&#34;bootstrapModalLabel&#34;&gt;Volunteer Application&lt;/h5&gt;&#xD;&#xA;              &lt;button type=&#34;button&#34; class=&#34;btn btn-close&#34; data-bs-dismiss=&#34;modal&#34; aria-label=&#34;close&#34;&gt;&lt;/button&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &lt;div class=&#34;modal-body&#34;&gt;&#xD;&#xA;            &lt;div class=&#34;container-fluid&#34;&gt;&#xD;&#xA;              &lt;form id=&#34;bootstrapModalForm&#34;&gt;&#xD;&#xA;                &lt;div class=&#34;row&#34;&gt;&#xD;&#xA;                  &lt;div class=&#34;col-sm-3&#34;&gt;&#xD;&#xA;                    &lt;div class=&#34;input-group date&#34; data-provide=&#34;datepicker&#34;&gt;&#xD;&#xA;                      &lt;div class=&#34;input-group-prepend&#34;&gt;&#xD;&#xA;                          &lt;span class=&#34;input-group-text&#34; id=&#34;dateLabel&#34;&gt;Date&lt;/span&gt;&#xD;&#xA;                      &lt;/div&gt;&#xD;&#xA;                      &lt;input id=&#34;datepicker1&#34; type=&#34;text&#34; class=&#34;form-control&#34; aria-describedby=&#34;dateLabel&#34; /&gt;&#xD;&#xA;                      &lt;div class=&#34;input-group-addon&#34;&gt;&#xD;&#xA;                          &lt;span class=&#34;glyphicon glyphicon-th&#34;&gt;&lt;/span&gt;&#xD;&#xA;                      &lt;/div&gt;&#xD;&#xA;                    &lt;/div&gt;&#xD;&#xA;                  &lt;/div&gt;&#xD;&#xA;                  &lt;div class=&#34;col-sm-8&#34;&gt;&#xD;&#xA;                    &lt;div class=&#34;input-group&#34;&gt;&#xD;&#xA;                      &lt;div class=&#34;input-group-prepend&#34;&gt;&#xD;&#xA;                          &lt;span class=&#34;input-group-text&#34; id=&#34;callsignLabel&#34;&gt;CallSign&lt;/span&gt;&#xD;&#xA;                      &lt;/div&gt;&#xD;&#xA;                      &lt;input id=&#34;callsign&#34; type=&#34;text&#34; class=&#34;form-control&#34; aria-describedby=&#34;callsignLabel&#34; /&gt;&#xD;&#xA;                      &lt;div class=&#34;input-group-append&#34;&gt;&#xD;&#xA;                        &lt;button class=&#34;btn btn-outline-secondary dropdown-toggle&#34; type=&#34;button&#34; data-toggle=&#34;dropdown&#34; aria-haspopup=&#34;true&#34; aria-expanded=&#34;false&#34;&gt;class&lt;/button&gt;&#xD;&#xA;                        &lt;div class=&#34;dropdown-menu&#34;&gt;&#xD;&#xA;                          &lt;a class=&#34;dropdown-item&#34; href=&#34;#&#34;&gt;Tech&lt;/a&gt;&#xD;&#xA;                          &lt;a class=&#34;dropdown-item&#34; href=&#34;#&#34;&gt;General&lt;/a&gt;&#xD;&#xA;                          &lt;a class=&#34;dropdown-item&#34; href=&#34;#&#34;&gt;Extra&lt;/a&gt;&#xD;&#xA;                          &lt;div role=&#34;separator&#34; class=&#34;dropdown-divider&#34;&gt;&lt;/div&gt;&#xD;&#xA;                          &lt;a class=&#34;dropdown-item&#34; href=&#34;#&#34;&gt;None&lt;/a&gt;&#xD;&#xA;                        &lt;/div&gt;&#xD;&#xA;                      &lt;/div&gt;&#xD;&#xA;                    &lt;/div&gt;&#xD;&#xA;                  &lt;/div&gt;&#xD;&#xA;                &lt;/div&gt;&#xD;&#xA;                &lt;div class=&#34;form-outline mb-4&#34;&gt;&#xD;&#xA;                  &lt;label class=&#34;col-sm-2 col-form-label&#34; for=&#34;bootstrapModalName&#34;&gt;Name&lt;/label&gt;&#xD;&#xA;                  &lt;input type=&#34;text&#34; id=&#34;bootstrapModalName&#34; class=&#34;form-control&#34; placeholder=&#34;First Last&#34;/&gt;&#xD;&#xA;                &lt;/div&gt;&#xD;&#xA;                &lt;div class=&#34;form-group mb-4&#34;&gt;&#xD;&#xA;                  &lt;input type=&#34;emailFrom&#34; id=&#34;bootstrapModalEmailFrom&#34; class=&#34;form-control&#34; /&gt;&#xD;&#xA;                  &lt;label class=&#34;form-label&#34; for=&#34;bootstrapModalEmailFrom&#34;&gt;Email address&lt;/label&gt;&#xD;&#xA;                  &lt;small id=&#34;emailHelp&#34; class=&#34;form-text text-muted&#34;&gt;We&#39;ll never share your email with anyone else.&lt;/small&gt;&#xD;&#xA;                &lt;/div&gt;&#xD;&#xA;                &lt;div class=&#34;form-check d-flex justify-content-center mb-4&#34;&gt;&#xD;&#xA;                  &lt;input class=&#34;form-check-input me-2&#34; type=&#34;checkbox&#34; value=&#34;&#34; id=&#34;bootstrapModalSendCopy&#34; checked /&gt;&#xD;&#xA;                  &lt;label class=&#34;form-check-label&#34; for=&#34;bootstrapModalSendCopy&#34;&gt;&#xD;&#xA;                      Send me a copy of this message&#xD;&#xA;                  &lt;/label&gt;&#xD;&#xA;                &lt;/div&gt;&#xD;&#xA;              &lt;/form&gt;&#xD;&#xA;            &lt;/div&gt;&#xD;&#xA;          &lt;/div&